# ─────────────────────────────────────────
#  SmartHydro ML API — Environment Config
# ─────────────────────────────────────────

FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-me-in-production

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/smarthydro?retryWrites=true&w=majority

# Database / collection names
DB_NAME=smarthydro
COLLECTION_READINGS=readings
COLLECTION_PREDICTIONS=predictions
COLLECTION_DOSING_LOGS=dosing_logs
COLLECTION_ALERTS=alerts
COLLECTION_GROWTH=growth_logs

# Model file paths  (place trained .h5 / .pt / .pkl files here)
LSTM_MODEL_PATH=saved_models/lstm_ph_temp.h5
CNN_MODEL_PATH=saved_models/resnet50_growth.pt
YOLO_MODEL_PATH=saved_models/yolov8_pest.pt
AUTOENCODER_MODEL_PATH=saved_models/autoencoder.h5
RL_POLICY_PATH=saved_models/ppo_dosing_policy.zip

# Inference settings
LSTM_LOOKBACK=24
AUTOENCODER_THRESHOLD=0.045
YOLO_CONF_THRESHOLD=0.5

# Crop-specific EC setpoints  (mS/cm) per growth stage
# Format: STAGE_INDEX (0=seedling,1=veg,2=flowering,3=harvest)
EC_SETPOINTS=0.8,1.4,1.8,1.6
PH_OPTIMAL_LOW=5.5
PH_OPTIMAL_HIGH=6.5
TEMP_OPTIMAL_LOW=18.0
TEMP_OPTIMAL_HIGH=30.0
